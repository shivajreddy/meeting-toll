# Microsoft Graph credentials.
# Copy this file to .env and fill in real values:  cp .env.example .env
# Get these from Entra ID > App registrations.

# Client-credentials flow (app-only auth)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Optional: a short-lived access token (~1h) for manual testing.
# This is what the current code reads via std::env::var("GRAPH_TOKEN").
GRAPH_TOKEN=
